# ═══════════════════════════════════════════════
# ZotMCP .gitignore
# ═══════════════════════════════════════════════

# ── Python ──
__pycache__/
*.py[cod]
*$py.class
*.so
*.pyd

# ── Distribution / packaging ──
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# ── Virtual environments ──
.env
.venv/
env/
venv/
ENV/
env.bak/
venv.bak/

# ── Testing ──
htmlcov/
.tox/
.nox/
.coverage
.coverage.*
.cache
nosetests.xml
coverage.xml
*.cover
*.py,cover
.hypothesis/
.pytest_cache/

# ── Translations ──
*.mo
*.pot

# ── IDE / Editor ──
.idea/
.vscode/
*.swp
*.swo
*~

# ── OS ──
.DS_Store
Thumbs.db
Desktop.ini
ehthumbs.db

# ── Node (mcp-remote / npx cache) ──
node_modules/

# ── Logs ──
*.log

# ── Secrets / credentials (CRITICAL) ──
*.env
.env.*
!.env.example
config.json
credential.yml
credential.yaml
secrets.*
*_secret*
*_private*

# ── Private / development folders ──
private/
dev/
backup/
temp/
*.bak

# ── ChromaDB (semantic search data) ──
chroma/
chroma_db/

# ── Spec workflow (MCP plugin cache) ──
.spec-workflow/

# ── Ad-hoc test scripts (not part of test suite) ──
test_hybrid_*.py
test_new_features.py

# ── Installer / PyInstaller ──
*.manifest
*.spec
pip-log.txt
pip-delete-this-directory.txt
